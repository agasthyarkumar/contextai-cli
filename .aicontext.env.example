# ── LLM Provider ──────────────────────────────────────────────────────────────
# Supported: groq | ollama
LLM_PROVIDER=groq

# ── Groq (default) ────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local, optional) ───────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Context settings ──────────────────────────────────────────────────────────
MAX_FILE_SIZE_KB=100
CONTEXT_FILE=context.json
CONTEXT_MD_FILE=context.md
IGNORE_DIRS=node_modules,.git,build,dist,__pycache__,.venv,venv,.next,.nuxt
IGNORE_EXTENSIONS=.pyc,.pyo,.pyd,.so,.dylib,.dll,.exe,.bin,.jpg,.jpeg,.png,.gif,.svg,.ico,.mp4,.mp3,.zip,.tar,.gz,.lock,.sum
